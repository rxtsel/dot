// solarized colors
// base #002B36
// gray #ADB8B8
// gold #B58900
// white #FFFFFF
// orange #CB4B16
// red #DC322F
// magenta #D33682
// violet #6C71C4
// blue #268BD2
// cyan #2AA198
// green #859900

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
                format_left   "{mode}{tabs}"
                format_center ""
                format_right  "#[fg=#ADB8B8,bg=#002B36]î‚˛#[fg=#002B36,bg=#ADB8B8] rxtsel-max #[fg=#002B36,bg=#ADB8B8]"
                format_space  ""

                mode_normal        "#[fg=#002B36,bg=#ADB8B8] {name}#[fg=#ADB8B8,bg=#ADB8B8]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"
                mode_resize        "#[fg=#002B36,bg=#D33682] {name}#[fg=#D33682,bg=#D33682]î‚°#[fg=#D33682,bg=#002B36]î‚°"
                mode_pane          "#[fg=#002B36,bg=#859900] {name}#[fg=#859900,bg=#859900]î‚°#[fg=#859900,bg=#002B36]î‚°"
                mode_tab           "#[fg=#002B36,bg=#268BD2] {name}#[fg=#268BD2,bg=#268BD2]î‚°#[fg=#268BD2,bg=#002B36]î‚°"
                mode_scroll        "#[fg=#002B36,bg=#268BD2] {name}#[fg=#268BD2,bg=#268BD2]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"
                mode_rename_tab    "#[fg=#002B36,bg=#CB4B16] {name}#[fg=#CB4B16,bg=#CB4B16]î‚°#[fg=#CB4B16,bg=#002B36]î‚°"
                mode_rename_pane   "#[fg=#002B36,bg=#CB4B16] {name}#[fg=#CB4B16,bg=#CB4B16]î‚°#[fg=#CB4B16,bg=#002B36]î‚°"
                mode_session       "#[fg=#002B36,bg=#6C71C4] {name}#[fg=#6C71C4,bg=#6C71C4]î‚°#[fg=#6C71C4,bg=#002B36]î‚°"
                mode_move          "#[fg=#002B36,bg=#ADB8B8] {name}#[fg=#ADB8B8,bg=#ADB8B8]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"
                mode_locked        "#[fg=#002B36,bg=#ADB8B8] {name}#[fg=#ADB8B8,bg=#ADB8B8]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"
                mode_enter_search  "#[fg=#002B36,bg=#ADB8B8] {name}#[fg=#ADB8B8,bg=#ADB8B8]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"
                mode_prompt        "#[fg=#002B36,bg=#ADB8B8] {name}#[fg=#ADB8B8,bg=#ADB8B8]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"
                mode_tmux          "#[fg=#002B36,bg=#ADB8B8] {name}#[fg=#ADB8B8,bg=#ADB8B8]î‚°#[fg=#ADB8B8,bg=#002B36]î‚°"

                tab_normal    "#[fg=#ADB8B8] {name} î‚±"
                tab_active    "#[fg=#002B36,bg=#B58900]î‚°#[fg=#FFFFFF,bg=#B58900,bold] {name} #[fg=#B58900]î‚°"
            }
        }
    }
}
